      "icons": [{ "src": "/logo96.png", "sizes": "96x96" }]
    },
    {
      "name": "Ask Dr. Bloom",
      "shortName": "Ask",
      "url": "/ask",
      "icons": [{ "src": "/logo96.png", "sizes": "96x96" }]
    }
  ]
